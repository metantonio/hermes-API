def _generate_hermes_response(\n        self,\n        message: str,\n        conversation: List[dict]\n    ) -> str:\n        \"\"\"\n        Generate Hermes AI response using Qwen3.5 local model.\n        Integrates with ~/.hermes/venv/hermes_llama_wrapper.py\n        \"\"\"\n        import sys\n        from pathlib import Path\n        \n        # Agregar hermes al path para importar el wrapper\n        HERMES_HOME = Path(\"~/.hermes\")\n        sys.path.insert(0, str(HERMES_HOME / \"hermes-agent\"))\n        \n        try:\n            # Importar el wrapper llama.cpp\n            from hermes_llama_wrapper import intercept_llm_call\n        except ImportError as e:\n            # Fallback si el wrapper no está disponible\n            print(f\"⚠️ Warning: Could not import hermes_llama_wrapper: {e}\")\n            print(\"  Using simulated response as fallback\")\n            \n            # Simple heuristic responses for demo\n            message_lower = message.lower()\n            \n            if \"hello\" in message_lower or \"hi\" in message_lower:\n                return \"Hello! How can I help you today?\"\n            elif \"help\" in message_lower:\n                return (\n                    \"I can help you with web data extraction, searching for information, \"\n                    \"and general queries. What would you like to know?\"\n                )\n            elif \"weather\" in message_lower:\n                return (\n                    \"I don't have real-time weather data access, but I can help you \"\n                    \"find weather APIs or websites that provide weather information.\"\n                )\n            elif \"stock\" in message_lower:\n                return (\n                    \"I can help you extract stock prices from financial websites \"\n                    \"if you provide a specific URL and the data you need.\"\n                )\n            elif \"search\" in message_lower:\n                return (\n                    \"I can search for information on the web and extract relevant \"\n                    \"data. What would you like me to search for?\"\n                )\n            else:\n                # Default response with context awareness\n                return (\n                    f\"I can help you with web data extraction and research. \"\n                    f\"Based on our conversation, you've asked about: {len(conversation)} topics. \"\n                    f\"How can I assist you further with web data or information extraction?\"\n                )\n        \n        # Construir prompt para el modelo Qwen3.5\n        system_prompt = \"\"\"Eres Hermes AI, un asistente inteligente especializado en:
- Extracción de datos web
- Investigación y búsqueda de información
- Análisis de datos
- Respuestas concisas y precisas

Responde de manera útil, precisa y segura. Mantén un tono profesional.\n\"\"\"\n        \n        # Construir mensaje completo con historial de conversación\n        full_prompt = f\"\"\"### System\n{system_prompt}\n\n### User\n{message}\n\n### Conversation History\n{conversation[-5:] if conversation else 'No previous messages'}\n\n### Assistant\n\"\"\"\n        \n        # Llamar al modelo local\n        try:\n            response = intercept_llm_call(\n                prompt=full_prompt,\n                temperature=0.7,\n                max_tokens=1024\n            )\n            return response.strip()\n        except Exception as e:\n            # Manejar errores gracefully\n            print(f\"❌ Error en Hermes AI: {e}\")\n            return \"Lo siento, estoy teniendo problemas técnicos. Por favor, intenta de nuevo más tarde.\"
