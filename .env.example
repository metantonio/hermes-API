# Hermes Web Data API - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================

# Application name and version
APP_NAME=Hermes Web Data API
APP_VERSION=1.0.0
APP_ENV=production

# Debug mode (set to false in production)
DEBUG=false

# ============================================================================
# Server Configuration
# ============================================================================

# Server host (use 127.0.0.1 for local development)
HOST=0.0.0.0
PORT=8000

# Number of worker processes (use 1 in development)
WORKERS=4

# ============================================================================
# Database Configuration
# ============================================================================

# Database connection URL
# PostgreSQL: postgresql://user:password@localhost:5432/hermes
# SQLite: sqlite:///./hermes.db
DB_URL=postgresql://user:password@localhost/hermes

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# Security Settings
# ============================================================================

# Secret key for JWT tokens and encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-chars-long

# JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600  # hours

# API key settings
API_KEY_MIN_LENGTH=32
API_KEY_MAX_LENGTH=128

# ============================================================================
# Rate Limiting
# ============================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60  # seconds
RATE_LIMIT_MAX=60  # requests per window

# ============================================================================
# CORS Configuration
# ============================================================================

# Allowed origins (comma-separated)
# Example: https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# ============================================================================
# Domain Whitelist
# ============================================================================

# Allowed domains for web extraction
# Example: example.com,api.example.com,another.example.com
ALLOWED_DOMAINS=

# ============================================================================
# Request/Response Limits
# ============================================================================

# Maximum request size (bytes)
MAX_REQUEST_SIZE=10485760  # 10 MB

# Maximum response size (bytes)
MAX_RESPONSE_SIZE=104857600  # 100 MB

# Maximum URL length
MAX_URL_LENGTH=2048

# ============================================================================
# Timeouts
# ============================================================================

# Request timeout (seconds)
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10
READ_TIMEOUT=30
TOTAL_TIMEOUT=60

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=

# ============================================================================
# Audit and Monitoring
# ============================================================================

# Enable audit logging
AUDIT_ENABLED=true

# External audit endpoint (if configured)
AUDIT_ENDPOINT=

# Audit retention days
AUDIT_RETENTION_DAYS=365

# ============================================================================
# Allowed Hosts (for TrustedHostMiddleware)
# ============================================================================

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=

# ============================================================================
# ============================================================================
# IMPORTANT: Security Best Practices
# ============================================================================
# 
# 1. NEVER commit .env file to version control
#    Add .env to your .gitignore file
#
# 2. Use strong secrets for SECRET_KEY (minimum 32 characters)
#    Generate: python -c "import secrets; print(secrets.token_hex(32))"
#
# 3. Rotate secrets regularly
#    Use a secrets manager in production
#
# 4. Never log secrets or sensitive data
#    Use LOG_LEVEL=DEBUG only in development
#
# 5. Use HTTPS in production
#    Set ALLOWED_ORIGINS to your HTTPS domain
#
# ============================================================================